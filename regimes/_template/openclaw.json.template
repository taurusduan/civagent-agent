{
  "$schema": "Template for OpenClaw agent configuration",
  "_regime": "{{REGIME_ID}}",
  "_instructions": "Replace all {{PLACEHOLDERS}} with actual values before use",
  "models": {
    "providers": {
      "{{PROVIDER}}": {
        "baseUrl": "{{BASE_URL}}",
        "apiKey": "{{API_KEY}}",
        "api": "{{API_FORMAT}}",
        "models": [
          {
            "id": "{{MODEL_ID}}",
            "name": "{{MODEL_NAME}}",
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "main": "{{MAIN_AGENT_ID}}",
    "list": []
  },
  "bindings": [],
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "open",
      "accounts": {}
    }
  }
}
