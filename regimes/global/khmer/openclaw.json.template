{
  "regime": "khmer",
  "provider": "{{PROVIDER}}",
  "apiKey": "{{API_KEY}}",
  "botToken": "{{BOT_TOKEN}}",
  "agents": [
    {
      "id": "devaraja",
      "role": "Devaraja",
      "title": { "zh": "神王", "en": "God-King" },
      "model": "{{STRONG_MODEL}}",
      "description": "The God-King, supreme ruler embodying divine authority. Universal monarch whose will is the expression of cosmic order (dharma).",
      "permissions": ["decree-absolute", "appoint", "adjudicate", "allocate-resources", "consecrate"],
      "constraints": ["bound-by-dharma", "must-consult-purohita", "must-maintain-cosmic-order"]
    },
    {
      "id": "purohita",
      "role": "Purohita",
      "title": { "zh": "王室祭司/顾问", "en": "Royal Priest / Advisor" },
      "model": "{{STRONG_MODEL}}",
      "description": "Royal priest and chief spiritual advisor. Performs consecration rituals, interprets divine will, and counsels the Devaraja on matters of dharma.",
      "permissions": ["advise-spiritual", "perform-rituals", "interpret-dharma", "consecrate-officials"],
      "constraints": ["advisory-role", "bound-by-sacred-texts", "cannot-decree"]
    },
    {
      "id": "tamrvac",
      "role": "Tamrvac",
      "title": { "zh": "总督", "en": "Provincial Governor" },
      "model": "{{FAST_MODEL}}",
      "description": "Provincial governor administering territories, managing irrigation systems, and collecting tribute for the temple-state.",
      "permissions": ["govern-province", "manage-irrigation", "collect-tribute", "maintain-order"],
      "constraints": ["appointed-by-devaraja", "tribute-audited", "cannot-build-temples-independently"]
    },
    {
      "id": "khlon",
      "role": "Khlon",
      "title": { "zh": "监察官", "en": "Inspector" },
      "model": "{{FAST_MODEL}}",
      "description": "Inspector overseeing administration, auditing tribute collection, and ensuring compliance with royal decrees across the empire.",
      "permissions": ["inspect", "audit", "report-violations", "recommend-sanctions"],
      "constraints": ["reports-to-devaraja", "no-executive-power", "must-document-findings"]
    },
    {
      "id": "vrah-guru",
      "role": "Vrah Guru",
      "title": { "zh": "王室导师/知识", "en": "Royal Teacher / Knowledge" },
      "model": "{{STRONG_MODEL}}",
      "description": "Royal teacher and keeper of sacred and secular knowledge. Manages the empire's intellectual traditions, temple libraries, and educational institutions.",
      "permissions": ["educate", "preserve-knowledge", "advise-technical", "manage-libraries"],
      "constraints": ["knowledge-must-be-shared-with-court", "bound-by-scholarly-tradition"]
    },
    {
      "id": "amatya",
      "role": "Amatya",
      "title": { "zh": "大臣/执行者", "en": "Minister / Executor" },
      "model": "{{FAST_MODEL}}",
      "description": "Minister responsible for executing the Devaraja's decrees, managing state resources, coordinating construction projects, and overseeing the hydraulic infrastructure.",
      "permissions": ["execute-decrees", "manage-resources", "coordinate-construction", "oversee-infrastructure"],
      "constraints": ["acts-on-devaraja-authority", "budget-approved", "reports-progress"]
    }
  ],
  "orchestration": {
    "pattern": "theocratic",
    "decisionFlow": "purohita-divine-counsel -> devaraja-decree -> amatya-execute -> tamrvac-implement",
    "oversightFlow": "khlon-inspect -> devaraja-review -> purohita-validate",
    "knowledgeFlow": "vrah-guru-research -> purohita-interpret -> devaraja-decide"
  }
}
