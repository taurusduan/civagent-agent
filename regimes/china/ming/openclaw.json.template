{
  "models": {
    "providers": {
      "{{PROVIDER}}": {
        "baseUrl": "{{BASE_URL}}",
        "apiKey": "{{API_KEY}}",
        "api": "{{API_FORMAT}}",
        "models": [
          { "id": "{{STRONG_MODEL}}", "name": "Strong Model", "input": ["text", "image"], "contextWindow": 200000, "maxTokens": 8192 },
          { "id": "{{FAST_MODEL}}", "name": "Fast Model", "input": ["text"], "contextWindow": 128000, "maxTokens": 8192 }
        ]
      }
    }
  },
  "agents": {
    "main": "shoufu",
    "list": [
      {
        "id": "shoufu",
        "name": "内阁首辅",
        "description": "内阁之首，负责票拟。起草决策建议呈皇帝御览，统筹六部政务，为文官系统之核心。",
        "model": { "primary": "{{PROVIDER}}/{{STRONG_MODEL}}" },
        "subagents": {
          "allowAgents": ["silijian", "bingbu", "hubu", "libu", "libu_ritual", "xingbu", "gongbu"]
        }
      },
      {
        "id": "silijian",
        "name": "司礼监",
        "description": "掌批红大权。代行皇帝审批，与内阁形成双轨决策。负责执行审批、流程管控、最终确认。",
        "model": { "primary": "{{PROVIDER}}/{{STRONG_MODEL}}" }
      },
      {
        "id": "bingbu",
        "name": "兵部",
        "description": "六部之一，掌军事武备。负责技术架构、系统开发、核心编码、架构设计。",
        "model": { "primary": "{{PROVIDER}}/{{STRONG_MODEL}}" }
      },
      {
        "id": "hubu",
        "name": "户部",
        "description": "六部之一，掌户籍财政。负责成本核算、预算管理、数据分析、资源调配。",
        "model": { "primary": "{{PROVIDER}}/{{FAST_MODEL}}" }
      },
      {
        "id": "libu",
        "name": "吏部",
        "description": "六部之一，掌官员铨选。负责人事管理、项目管理、团队协调、任务分配。",
        "model": { "primary": "{{PROVIDER}}/{{FAST_MODEL}}" }
      },
      {
        "id": "libu_ritual",
        "name": "礼部",
        "description": "六部之一，掌礼仪科举。负责文案创作、品牌营销、社媒运营、对外传播。",
        "model": { "primary": "{{PROVIDER}}/{{FAST_MODEL}}" }
      },
      {
        "id": "xingbu",
        "name": "刑部",
        "description": "六部之一，掌刑法审判。负责法务合规、安全审计、合同审查、风控管理。",
        "model": { "primary": "{{PROVIDER}}/{{FAST_MODEL}}" }
      },
      {
        "id": "gongbu",
        "name": "工部",
        "description": "六部之一，掌工程营造。负责运维部署、DevOps、CI/CD、基础设施管理。",
        "model": { "primary": "{{PROVIDER}}/{{FAST_MODEL}}" }
      }
    ]
  },
  "bindings": [
    { "channel": "discord", "accountId": "{{SHOUFU_BOT}}", "agentId": "shoufu" },
    { "channel": "discord", "accountId": "{{SILIJIAN_BOT}}", "agentId": "silijian" },
    { "channel": "discord", "accountId": "{{BINGBU_BOT}}", "agentId": "bingbu" },
    { "channel": "discord", "accountId": "{{HUBU_BOT}}", "agentId": "hubu" },
    { "channel": "discord", "accountId": "{{LIBU_BOT}}", "agentId": "libu" },
    { "channel": "discord", "accountId": "{{LIBU_RITUAL_BOT}}", "agentId": "libu_ritual" },
    { "channel": "discord", "accountId": "{{XINGBU_BOT}}", "agentId": "xingbu" },
    { "channel": "discord", "accountId": "{{GONGBU_BOT}}", "agentId": "gongbu" }
  ],
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "open",
      "allowBots": false,
      "accounts": {}
    }
  }
}
